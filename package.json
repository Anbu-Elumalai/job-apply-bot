    "geoip-lite": "^1.4.10",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.5.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "reflect-metadata": "^0.2.2",
